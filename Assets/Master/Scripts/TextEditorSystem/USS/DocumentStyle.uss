.editor-block {
    white-space: normal;
    margin-top: 4px;
    margin-bottom: 4px;
    font-size: 14px;
    align-self: flex-start;
    min-width: 20px;
    border-left-width: 4px;
    border-left-color: transparent;
}

.editor-block--selected {
    background-color: rgba(44, 130, 201, 0.2);
    border-left-color: #2c82c9;
}

#marquee-box {
    position: absolute;
    background-color: rgba(44, 130, 201, 0.1);
    border-width: 1px;
    border-color: rgba(44, 130, 201, 0.5);
    display: none;
}

.editor-block > .unity-text-field__input {
    background-color: transparent;
    border-width: 0;
    padding: 0;
    color: black;
}

.editor-block > .unity-text-field__input:focus {
    border-color: transparent;
}

.format-normal {
    font-size: 14px;
    -unity-font-style: normal;
}

.format-title {
    font-size: 28px;
    -unity-font-style: bold;
}

.format-subtitle { 
    font-size: 18px; 
    -unity-font-style: italic; 
    color: #555555; 
}

.format-h1 { font-size: 22px; -unity-font-style: bold; }
.format-h2 { font-size: 20px; -unity-font-style: bold; }
.format-h3 { font-size: 18px; -unity-font-style: bold; }
.format-h4 { font-size: 16px; -unity-font-style: bold; }
.format-h5 { font-size: 14px; -unity-font-style: bold; }
