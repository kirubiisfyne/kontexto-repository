  lines:
  - speaker: {fileID: 11400000, guid: 6a1e7779440a64ef289941e3b5585ec0, type: 2}
    text: You there! Can you help me look for a sphere?
  - speaker: {fileID: 11400000, guid: 6a1e7779440a64ef289941e3b5585ec0, type: 2}
    text: NPC D needs it, I'll be doomed if it'll be gone!
  - speaker: {fileID: 11400000, guid: ebadf8833755745b6b6e30d28d7c39ce, type: 2}
    text: Sure, I'll do my best!
  - speaker: {fileID: 11400000, guid: 6a1e7779440a64ef289941e3b5585ec0, type: 2}
    text: Thank you very much!
