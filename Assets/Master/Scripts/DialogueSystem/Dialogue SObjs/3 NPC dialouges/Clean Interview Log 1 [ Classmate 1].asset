  m_Script: {fileID: 11500000, guid: 55f8968ff7bf14a74b702a9c01b62d8b, type: 3}
  m_Name: 'Clean Interview Log 1 [ Classmate 1]'
  m_EditorClassIdentifier: Assembly-CSharp::Master.Scripts.DialogueSystem.Conversation
  lines:
  - speaker: {fileID: 11400000, guid: 28c1e01ffd8384086aad5f6bf7f9f40d, type: 2}
    text: "Whoa\u2026 "
  - speaker: {fileID: 11400000, guid: 28c1e01ffd8384086aad5f6bf7f9f40d, type: 2}
    text: "This interview file is painful to read. It\u2019s just one giant wall
      of text."
  - speaker: {fileID: 11400000, guid: 28c1e01ffd8384086aad5f6bf7f9f40d, type: 2}
    text: Try fixing the spacing first. Separate the paragraphs, adjust the indents.
  - speaker: {fileID: 11400000, guid: 28c1e01ffd8384086aad5f6bf7f9f40d, type: 2}
    text: If the questions and answers are easier to spot, the clues might show up
      too.
