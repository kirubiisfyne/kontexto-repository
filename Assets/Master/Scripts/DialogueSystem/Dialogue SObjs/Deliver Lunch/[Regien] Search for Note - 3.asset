  m_Script: {fileID: 11500000, guid: 55f8968ff7bf14a74b702a9c01b62d8b, type: 3}
  m_Name: '[Regien] Search for Note - 3'
  m_EditorClassIdentifier: Assembly-CSharp::Master.Scripts.DialogueSystem.Conversation
  lines:
  - speaker: {fileID: 11400000, guid: 04c44a04ade27492284b5d1eb85ad4fe, type: 2}
    text: "Well, regardless of how you got it, thank you. You\u2019re a lifesaver.
      Tell Ritsu he\u2019s lucky I\u2019m in a good mood, or I\u2019d be charging
      him interest."
  - speaker: {fileID: 11400000, guid: c0b6716d4b3ae41488323461179cf4a7, type: 2}
    text: I'll pass that along. Just glad to be out of the middle of this.
